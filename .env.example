# The offline eval needs NO secrets: it boots a native ephemeral Postgres over a
# unix socket with trust auth. The names below are read only OUTSIDE `make eval`
# (the live quality judge and the optional live CRM connectors). Copy this file to
# `.env` (gitignored) and fill what you want to light up.

# Live quality judge (read automatically by the Anthropic SDK).
# ANTHROPIC_API_KEY=

# External CRM connector (LiveCRMConnector) — live/demo lane only. The offline eval
# uses the StubCRMConnector and needs neither. Per-tenant credentialed.
# CRM_BASE_URL=
# CRM_API_TOKEN=

# Data-plane connectors (Salesforce / Attio / Gainsight / Rocketlane) read per-source
# credentials named in eval connector specs (e.g. ULTRA_CSM_SALESFORCE_*). See
# src/ultra_csm/data_plane/connector_catalog.py for the exact variables per connector.

# Optional dedicated no-login API for the rollback-isolated synthetic sandbox.
# Leave unset in the hosted static build to show the honest read-only V1 fallback.
NEXT_PUBLIC_ACTION_CONTROL_SANDBOX_API=
ULTRA_CSM_SANDBOX_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
