{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ui && npm ci",
  "buildCommand": "cd ui && NEXT_PUBLIC_UCSM_READONLY_DEMO=1 npm run build",
  "outputDirectory": "ui/out",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/ui/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/ui/:path*",
      "destination": "/:path*"
    }
  ]
}
