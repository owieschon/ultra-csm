{
  "framework": null,
  "installCommand": "cd ui && npm ci",
  "buildCommand": "cd ui && NEXT_PUBLIC_UCSM_READONLY_DEMO=1 npm run build",
  "outputDirectory": "ui/out",
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/ui/comms-review",
      "destination": "/comms-review/index.html"
    },
    {
      "source": "/ui/comms-review/",
      "destination": "/comms-review/index.html"
    },
    {
      "source": "/ui/action-control",
      "destination": "/action-control/index.html"
    },
    {
      "source": "/ui/action-control/",
      "destination": "/action-control/index.html"
    },
    {
      "source": "/ui/",
      "destination": "/index.html"
    },
    {
      "source": "/ui/:path*",
      "destination": "/:path*"
    }
  ]
}
